{
  "$schema": "https://schema.management.azure.com/schemas/2018-05-01/subscriptionDeploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "SC-500 Lab 3C - Configure AI Gateway and Foundry Security Controls - Setup Template. This template provisions an Azure API Management instance, Azure AI Foundry hub and project, Azure OpenAI service with gpt-5.4-mini deployment, and configures the APIM API to route to the Foundry model endpoint in an intentionally unsecured state for students to remediate."
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "eastus",
      "allowedValues": [
        "eastus",
        "eastus2",
        "westus",
        "westus2",
        "southcentralus",
        "northcentralus",
        "westeurope",
        "northeurope",
        "australiaeast",
        "southeastasia"
      ],
      "metadata": {
        "description": "Azure region for all resources. Use a region that supports Azure OpenAI and API Management."
      }
    },
    "labInstanceId": {
      "type": "string",
      "defaultValue": "@lab.LabInstance.Id",
      "minLength": 1,
      "maxLength": 8,
      "metadata": {
        "description": "The Skillable lab instance ID. Used to generate globally unique resource names. Auto-populated by Skillable using @lab.LabInstance.Id variable."
      }
    },
    "publisherEmail": {
      "type": "string",
      "defaultValue": "admin@contoso.com",
      "metadata": {
        "description": "Email address for the API Management publisher. Required by APIM."
      }
    },
    "publisherName": {
      "type": "string",
      "defaultValue": "Contoso",
      "metadata": {
        "description": "Organization name for the API Management publisher."
      }
    }
  },
  "variables": {
    "resourceGroupName": "sc500-lab3c-rg",
    "apimName": "[concat('sc500-lab3c-apim-', parameters('labInstanceId'))]",
    "openAiName": "[concat('sc500-lab3c-ai-', parameters('labInstanceId'))]",
    "aiHubName": "[concat('sc500-lab3c-hub-', parameters('labInstanceId'))]",
    "aiProjectName": "sc500-lab3c-foundry",
    "storageAccountName": "[concat('sc500lab3c', parameters('labInstanceId'))]",
    "keyVaultName": "[concat('sc500-kv-', parameters('labInstanceId'))]",
    "appInsightsName": "sc500-lab3c-insights",
    "logAnalyticsName": "sc500-lab3c-logs",
    "modelDeploymentName": "gpt-5.4-mini",
    "modelName": "gpt-5.4-mini",
    "modelVersion": "2026-03-17",
    "apiName": "sc500-foundry-api"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/resourceGroups",
      "apiVersion": "2021-04-01",
      "name": "[variables('resourceGroupName')]",
      "location": "[parameters('location')]",
      "tags": {
        "lab": "SC-500-Lab-3C",
        "purpose": "AI Gateway and Foundry Security"
      },
      "properties": {}
    },
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2022-09-01",
      "name": "sc500-lab3c-infrastructure",
      "resourceGroup": "[variables('resourceGroupName')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/resourceGroups', variables('resourceGroupName'))]"
      ],
      "properties": {
        "mode": "Incremental",
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "parameters": {
          "location": { "value": "[parameters('location')]" },
          "apimName": { "value": "[variables('apimName')]" },
          "openAiName": { "value": "[variables('openAiName')]" },
          "aiHubName": { "value": "[variables('aiHubName')]" },
          "aiProjectName": { "value": "[variables('aiProjectName')]" },
          "storageAccountName": { "value": "[variables('storageAccountName')]" },
          "keyVaultName": { "value": "[variables('keyVaultName')]" },
          "appInsightsName": { "value": "[variables('appInsightsName')]" },
          "logAnalyticsName": { "value": "[variables('logAnalyticsName')]" },
          "modelDeploymentName": { "value": "[variables('modelDeploymentName')]" },
          "modelName": { "value": "[variables('modelName')]" },
          "modelVersion": { "value": "[variables('modelVersion')]" },
          "apiName": { "value": "[variables('apiName')]" },
          "publisherEmail": { "value": "[parameters('publisherEmail')]" },
          "publisherName": { "value": "[parameters('publisherName')]" }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "location": { "type": "string" },
            "apimName": { "type": "string" },
            "openAiName": { "type": "string" },
            "aiHubName": { "type": "string" },
            "aiProjectName": { "type": "string" },
            "storageAccountName": { "type": "string" },
            "keyVaultName": { "type": "string" },
            "appInsightsName": { "type": "string" },
            "logAnalyticsName": { "type": "string" },
            "modelDeploymentName": { "type": "string" },
            "modelName": { "type": "string" },
            "modelVersion": { "type": "string" },
            "apiName": { "type": "string" },
            "publisherEmail": { "type": "string" },
            "publisherName": { "type": "string" }
          },
          "variables": {
            "openAiEndpoint": "[concat('https://', parameters('openAiName'), '.openai.azure.com')]"
          },
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces",
              "apiVersion": "2022-10-01",
              "name": "[parameters('logAnalyticsName')]",
              "location": "[parameters('location')]",
              "properties": {
                "sku": { "name": "PerGB2018" },
                "retentionInDays": 30
              }
            },
            {
              "type": "Microsoft.Insights/components",
              "apiVersion": "2020-02-02",
              "name": "[parameters('appInsightsName')]",
              "location": "[parameters('location')]",
              "kind": "web",
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
              ],
              "properties": {
                "Application_Type": "web",
                "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('logAnalyticsName'))]"
              }
            },
            {
              "type": "Microsoft.Storage/storageAccounts",
              "apiVersion": "2023-01-01",
              "name": "[parameters('storageAccountName')]",
              "location": "[parameters('location')]",
              "sku": { "name": "Standard_LRS" },
              "kind": "StorageV2",
              "properties": {
                "accessTier": "Hot",
                "allowBlobPublicAccess": false,
                "minimumTlsVersion": "TLS1_2",
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                  "services": {
                    "blob": { "enabled": true },
                    "file": { "enabled": true }
                  },
                  "keySource": "Microsoft.Storage"
                }
              }
            },
            {
              "type": "Microsoft.KeyVault/vaults",
              "apiVersion": "2023-02-01",
              "name": "[parameters('keyVaultName')]",
              "location": "[parameters('location')]",
              "properties": {
                "sku": {
                  "family": "A",
                  "name": "standard"
                },
                "tenantId": "[subscription().tenantId]",
                "enabledForDeployment": false,
                "enabledForDiskEncryption": false,
                "enabledForTemplateDeployment": false,
                "enableRbacAuthorization": true,
                "enableSoftDelete": true,
                "softDeleteRetentionInDays": 7,
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.CognitiveServices/accounts",
              "apiVersion": "2024-04-01-preview",
              "name": "[parameters('openAiName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "S0"
              },
              "kind": "OpenAI",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "customSubDomainName": "[parameters('openAiName')]",
                "publicNetworkAccess": "Enabled",
                "networkAcls": {
                  "defaultAction": "Allow"
                },
                "disableLocalAuth": false
              }
            },
            {
              "type": "Microsoft.CognitiveServices/accounts/deployments",
              "apiVersion": "2024-04-01-preview",
              "name": "[concat(parameters('openAiName'), '/', parameters('modelDeploymentName'))]",
              "dependsOn": [
                "[resourceId('Microsoft.CognitiveServices/accounts', parameters('openAiName'))]"
              ],
              "sku": {
                "name": "GlobalStandard",
                "capacity": 10
              },
              "properties": {
                "model": {
                  "format": "OpenAI",
                  "name": "[parameters('modelName')]",
                  "version": "[parameters('modelVersion')]"
                },
                "versionUpgradeOption": "OnceNewDefaultVersionAvailable",
                "raiPolicyName": "Microsoft.Default"
              }
            },
            {
              "type": "Microsoft.MachineLearningServices/workspaces",
              "apiVersion": "2024-04-01-preview",
              "name": "[parameters('aiHubName')]",
              "location": "[parameters('location')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "kind": "Hub",
              "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
                "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
                "[resourceId('Microsoft.Insights/components', parameters('appInsightsName'))]",
                "[resourceId('Microsoft.CognitiveServices/accounts', parameters('openAiName'))]"
              ],
              "properties": {
                "friendlyName": "SC500 Lab 3C AI Hub",
                "description": "Azure AI Foundry Hub for SC-500 Lab 3C - AI Gateway and Security Controls",
                "storageAccount": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
                "keyVault": "[resourceId('Microsoft.KeyVault/vaults', parameters('keyVaultName'))]",
                "applicationInsights": "[resourceId('Microsoft.Insights/components', parameters('appInsightsName'))]",
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.MachineLearningServices/workspaces",
              "apiVersion": "2024-04-01-preview",
              "name": "[parameters('aiProjectName')]",
              "location": "[parameters('location')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "kind": "Project",
              "dependsOn": [
                "[resourceId('Microsoft.MachineLearningServices/workspaces', parameters('aiHubName'))]"
              ],
              "properties": {
                "friendlyName": "sc500-lab3c-foundry",
                "description": "Azure AI Foundry Project for SC-500 Lab 3C",
                "hubResourceId": "[resourceId('Microsoft.MachineLearningServices/workspaces', parameters('aiHubName'))]",
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.ApiManagement/service",
              "apiVersion": "2023-05-01-preview",
              "name": "[parameters('apimName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Consumption",
                "capacity": 0
              },
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "publisherEmail": "[parameters('publisherEmail')]",
                "publisherName": "[parameters('publisherName')]",
                "publicNetworkAccess": "Enabled"
              }
            },
            {
              "type": "Microsoft.ApiManagement/service/apis",
              "apiVersion": "2023-05-01-preview",
              "name": "[concat(parameters('apimName'), '/', parameters('apiName'))]",
              "dependsOn": [
                "[resourceId('Microsoft.ApiManagement/service', parameters('apimName'))]",
                "[resourceId('Microsoft.CognitiveServices/accounts/deployments', parameters('openAiName'), parameters('modelDeploymentName'))]"
              ],
              "properties": {
                "displayName": "SC500 Foundry API",
                "description": "Pre-configured API routing to Azure OpenAI gpt-5.4-mini deployment for SC-500 Lab 3C. Initially unsecured - students will apply rate limiting, subscription key authentication, and content safety controls.",
                "subscriptionRequired": false,
                "path": "sc500-foundry-api",
                "protocols": [ "https" ],
                "serviceUrl": "[concat(variables('openAiEndpoint'), '/openai')]",
                "apiVersion": "2024-02-01",
                "apiVersionSetId": "",
                "isCurrent": true,
                "type": "http",
                "format": "openapi+json",
                "value": "[concat('{\"openapi\":\"3.0.0\",\"info\":{\"title\":\"Azure OpenAI API\",\"version\":\"2024-02-01\"},\"servers\":[{\"url\":\"', variables('openAiEndpoint'), '/openai\"}],\"paths\":{\"/deployments/', parameters('modelDeploymentName'), '/chat/completions\":{\"post\":{\"summary\":\"Create chat completion\",\"operationId\":\"chatCompletions\",\"parameters\":[{\"name\":\"api-version\",\"in\":\"query\",\"required\":true,\"schema\":{\"type\":\"string\",\"default\":\"2024-02-01\"}}],\"requestBody\":{\"required\":true,\"content\":{\"application/json\":{\"schema\":{\"type\":\"object\",\"properties\":{\"messages\":{\"type\":\"array\"},\"max_tokens\":{\"type\":\"integer\"}}}}}},\"responses\":{\"200\":{\"description\":\"Success\"}}}}}}')]"
              }
            },
            {
              "type": "Microsoft.ApiManagement/service/backends",
              "apiVersion": "2023-05-01-preview",
              "name": "[concat(parameters('apimName'), '/openai-backend')]",
              "dependsOn": [
                "[resourceId('Microsoft.ApiManagement/service', parameters('apimName'))]",
                "[resourceId('Microsoft.CognitiveServices/accounts', parameters('openAiName'))]"
              ],
              "properties": {
                "description": "Azure OpenAI backend for SC-500 Lab 3C",
                "url": "[variables('openAiEndpoint')]",
                "protocol": "http",
                "credentials": {
                  "header": {
                    "api-key": [ "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', parameters('openAiName')), '2024-04-01-preview').key1]" ]
                  }
                }
              }
            }
          ],
          "outputs": {
            "openAiEndpoint": {
              "type": "string",
              "value": "[variables('openAiEndpoint')]"
            },
            "openAiKey": {
              "type": "string",
              "value": "[listKeys(resourceId('Microsoft.CognitiveServices/accounts', parameters('openAiName')), '2024-04-01-preview').key1]"
            },
            "apimGatewayUrl": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ApiManagement/service', parameters('apimName'))).gatewayUrl]"
            },
            "aiProjectId": {
              "type": "string",
              "value": "[resourceId('Microsoft.MachineLearningServices/workspaces', parameters('aiProjectName'))]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[variables('resourceGroupName')]"
    },
    "apimName": {
      "type": "string",
      "value": "[variables('apimName')]"
    },
    "openAiAccountName": {
      "type": "string",
      "value": "[variables('openAiName')]"
    },
    "aiHubName": {
      "type": "string",
      "value": "[variables('aiHubName')]"
    },
    "aiProjectName": {
      "type": "string",
      "value": "[variables('aiProjectName')]"
    },
    "modelDeploymentName": {
      "type": "string",
      "value": "[variables('modelDeploymentName')]"
    },
    "setupInstructions": {
      "type": "string",
      "value": "The infrastructure has been deployed. IMPORTANT: The Azure AI Foundry project requires additional configuration: 1) Navigate to https://ai.azure.com and select the sc500-lab3c-foundry project. 2) Add a connection to the Azure OpenAI service. 3) Ensure the gpt-5.4-mini deployment is visible in Models + endpoints. The API Management API (sc500-foundry-api) is intentionally configured with NO subscription requirement and NO rate limit policy - students will apply these controls during the lab."
    }
  }
}
